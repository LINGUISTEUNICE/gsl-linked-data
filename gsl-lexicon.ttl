# ---------------------------------------------------------------------------
# 5. SLEEP
# ---------------------------------------------------------------------------

gsl:entry_SLEEP
    a ontolex:LexicalEntry ;
    rdfs:label "SLEEP"@en ;
    ontolex:canonicalForm gsl:form_SLEEP ;
