    a ontolex:Form ;
    ontolex:writtenRep "SLEEP"@en .

gsl:phon_SLEEP
    a sldc:Manual ;
    sldc:handshape "open-B both hands — flat, fingers together" ;
    sldc:location "face / cheek area" ;
    sldc:orientation "palms facing face" ;
    sldc:movement "hands converge toward face; head tilts laterally" ;
    sldc:handedness "two-handed" .

gsl:nmm_SLEEP
    a gsl:NonManualMarker ;
    gsl:facialExpression "eyes closed or lowered — semantically obligatory" ;
    gsl:headMovement "lateral head tilt" .


