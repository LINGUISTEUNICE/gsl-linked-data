# ===========================================================================
# GSL Linked Data — Ghanaian Sign Language Lexicon (pilot, 18 signs)
# ===========================================================================
# Author      : [Your name]
# Date        : 2026
# License     : CC BY 4.0
# Source data : Fragkiadakis, Nyst & Nyarko (2021). Ghanaian Sign Language
#               Lexicon. Zenodo. https://doi.org/10.5281/zenodo.4533753
#               (signs FATHER and HAPPY: author's own GSL knowledge,
#               cross-referenced against GNAD dictionary)
# Ontologies  : OntoLex-Lemon  https://www.w3.org/community/ontolex/
#               Declerck (2022) sl-onto  https://github.com/Declerck/sl-onto
# Description : A pilot RDF/Linked Data representation of 18 GSL signs,
#               modelling manual and non-manual phonological features
#               using the sldc ontology and OntoLex-Lemon. The first
#               Linked Data treatment of Ghanaian Sign Language.
# ===========================================================================

# ---------------------------------------------------------------------------
# PREFIX DECLARATIONS
# ---------------------------------------------------------------------------

@prefix gsl:     <https://example.org/gsl/> .
@prefix ontolex: <http://www.w3.org/ns/lemon/ontolex#> .
@prefix lexinfo: <http://www.lexinfo.net/ontology/3.0/lexinfo#> .
@prefix sldc:    <https://github.com/Declerck/sl-onto#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:      <http://purl.org/dc/elements/1.1/> .
@prefix dct:     <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix void:    <http://rdfs.org/ns/void#> .

# ---------------------------------------------------------------------------
# DATASET DESCRIPTION
# ---------------------------------------------------------------------------

<https://example.org/gsl/>
    a void:Dataset , owl:Ontology ;
    dc:title "Ghanaian Sign Language Linked Data — Pilot Dataset"@en ;
    dc:description """A pilot Linked Data representation of 18 signs from
    Ghanaian Sign Language (GSL), modelling manual and non-manual phonological
    features using OntoLex-Lemon and the Declerck (2022) sign language
    ontology (sldc). This is the first RDF treatment of GSL vocabulary."""@en ;
    dc:creator "Your Name"@en ;
    dc:language "gse" ;
    dct:license <https://creativecommons.org/licenses/by/4.0/> ;
    dct:created "2026"^^xsd:gYear ;
    dct:source <https://doi.org/10.5281/zenodo.4533753> ;
    rdfs:seeAlso <https://aclanthology.org/2022.lrec-1.423/> .

# ---------------------------------------------------------------------------
# GSL-SPECIFIC EXTENSIONS
# (features not covered by sldc or needing local values)
# ---------------------------------------------------------------------------

gsl:iconicityHigh    a owl:NamedIndividual ; rdfs:label "high iconicity"@en .
gsl:iconicityMedium  a owl:NamedIndividual ; rdfs:label "medium iconicity"@en .
gsl:iconicityLow     a owl:NamedIndividual ; rdfs:label "low iconicity"@en .

gsl:hasIconicity     a owl:ObjectProperty ;
    rdfs:label "has iconicity"@en ;
    rdfs:comment "Relates a sign to its iconicity rating"@en .

gsl:hasNonManualMarker a owl:ObjectProperty ;
    rdfs:label "has non-manual marker"@en ;
    rdfs:comment "Relates a sign to its non-manual annotation tier"@en .

gsl:NonManualMarker  a owl:Class ;
    rdfs:label "Non-manual marker"@en ;
    rdfs:comment "A non-manual phonological feature: facial expression, mouth pattern, head movement"@en .

gsl:FacialExpression a owl:Class ; rdfs:subClassOf gsl:NonManualMarker ;
    rdfs:label "Facial expression"@en .
gsl:MouthPattern     a owl:Class ; rdfs:subClassOf gsl:NonManualMarker ;
    rdfs:label "Mouth pattern"@en .
gsl:HeadMovement     a owl:Class ; rdfs:subClassOf gsl:NonManualMarker ;
    rdfs:label "Head movement"@en .

gsl:sourceZenodo     a owl:NamedIndividual ;
    rdfs:label "Fragkiadakis, Nyst & Nyarko (2021) GSL Lexicon"@en ;
    rdfs:seeAlso <https://doi.org/10.5281/zenodo.4533753> .

gsl:sourceOwnKnowledge a owl:NamedIndividual ;
    rdfs:label "Author's own GSL knowledge, cross-ref GNAD dictionary"@en .


# ===========================================================================
# SIGNS — each modelled as an ontolex:LexicalEntry with:
#   - ontolex:canonicalForm  → the written gloss
#   - sldc:hasPhonology      → manual feature node (sldc:Manual)
#   - gsl:hasNonManualMarker → non-manual feature node (gsl:NonManualMarker)
#   - gsl:hasIconicity       → iconicity rating
#   - prov:wasDerivedFrom    → data source
# ===========================================================================


# ---------------------------------------------------------------------------
# 1. MOTHER
# ---------------------------------------------------------------------------

gsl:entry_MOTHER
    a ontolex:LexicalEntry ;
    rdfs:label "MOTHER"@en ;
    ontolex:canonicalForm gsl:form_MOTHER ;
    lexinfo:partOfSpeech lexinfo:noun ;
    sldc:hasPhonology gsl:phon_MOTHER ;
    gsl:hasNonManualMarker gsl:nmm_MOTHER ;
    gsl:hasIconicity gsl:iconicityHigh ;
    prov:wasDerivedFrom gsl:sourceZenodo .

gsl:form_MOTHER
    a ontolex:Form ;
    ontolex:writtenRep "MOTHER"@en .

gsl:phon_MOTHER
    a sldc:Manual ;
    sldc:handshape "open-5 hand — all fingers extended, spread" ;
    sldc:location "chest / sternum" ;
    sldc:orientation "palm toward body" ;
    sldc:movement "static bilateral hold, both hands contact chest" ;
    sldc:handedness "two-handed" .

gsl:nmm_MOTHER
    a gsl:NonManualMarker ;
    gsl:facialExpression "neutral to warm" ;
    gsl:mouthPattern "mouth pattern: 'mum'" .


# ---------------------------------------------------------------------------
# 2. FATHER  (source: author's own GSL knowledge)
# ---------------------------------------------------------------------------

gsl:entry_FATHER
    a ontolex:LexicalEntry ;
    rdfs:label "FATHER"@en ;
    ontolex:canonicalForm gsl:form_FATHER ;
    lexinfo:partOfSpeech lexinfo:noun ;
    sldc:hasPhonology gsl:phon_FATHER ;
    gsl:hasNonManualMarker gsl:nmm_FATHER ;
    gsl:hasIconicity gsl:iconicityHigh ;
    prov:wasDerivedFrom gsl:sourceOwnKnowledge .

gsl:form_FATHER
    a ontolex:Form ;
    ontolex:writtenRep "FATHER"@en .

gsl:phon_FATHER
    a sldc:Manual ;
    sldc:handshape "open-5 hand — all fingers extended" ;
    sldc:location "forehead / temple" ;
    sldc:orientation "palm toward head" ;
    sldc:movement "static hold or single tap at forehead" ;
    sldc:handedness "two-handed" .

gsl:nmm_FATHER
    a gsl:NonManualMarker ;
    gsl:facialExpression "neutral" ;
    gsl:mouthPattern "mouth pattern: 'dad'" .


