    a ontolex:Form ;
    ontolex:writtenRep "HAPPY"@en .

gsl:phon_HAPPY
    a sldc:Manual ;
    sldc:handshape "open-B / 5-hand both — fingers extended and spread" ;
    sldc:location "chest" ;
